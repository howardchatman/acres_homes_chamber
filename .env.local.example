# ============================================================
# AcresHOME Chamber — Environment Variables
# Copy this file to .env.local and fill in all values
# Add these same variables to Vercel → Settings → Environment Variables
# ============================================================

# Supabase — https://supabase.com/dashboard/project/lwyrpbvhltezdkdtrvkh/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://lwyrpbvhltezdkdtrvkh.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=        ← paste "anon public" key from Supabase API settings
SUPABASE_SERVICE_ROLE_KEY=            ← paste "service_role" key from Supabase API settings

# Stripe — https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Email (Resend) — https://resend.com/api-keys
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@acreshomechamber.com

# App
NEXT_PUBLIC_SITE_URL=https://chamber.chatmaninc.com

# Stripe Price IDs — add after creating membership products in Stripe dashboard
STRIPE_PRICE_COMMUNITY_MEMBER=price_...
STRIPE_PRICE_STANDARD_BUSINESS=price_...
STRIPE_PRICE_PREMIUM_PARTNER=price_...
STRIPE_PRICE_SPONSOR=price_...
